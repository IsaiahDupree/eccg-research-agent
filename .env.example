GITHUB_TOKEN=
# Google API key (for YouTube + Drive demos)
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# --- Config ---
ECCG_CACHE_DIR=.cache
ECCG_NICHE=event_camera
